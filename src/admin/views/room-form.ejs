<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hotel Bot Admin - <%= room ? 'Edit' : 'New' %> Room</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('layout') %>
  <main class="content">
    <div class="page-header">
      <h1><%= room ? 'Edit' : 'New' %> Room</h1>
      <a href="/admin/rooms" class="btn">← Back</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/rooms" class="form-card">
      <% if (room && room.id) { %>
        <input type="hidden" name="id" value="<%= room.id %>">
      <% } %>

      <div class="form-row">
        <div class="form-group">
          <label>Name *</label>
          <input type="text" name="name" value="<%= room ? room.name : '' %>" required>
        </div>
        <div class="form-group">
          <label>Type</label>
          <select name="type">
            <option value="standard" <%= room && room.type === 'standard' ? 'selected' : '' %>>Standard</option>
            <option value="superior" <%= room && room.type === 'superior' ? 'selected' : '' %>>Superior</option>
            <option value="deluxe" <%= room && room.type === 'deluxe' ? 'selected' : '' %>>Deluxe</option>
            <option value="suite" <%= room && room.type === 'suite' ? 'selected' : '' %>>Suite</option>
            <option value="family" <%= room && room.type === 'family' ? 'selected' : '' %>>Family</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Price per Night (USD) *</label>
          <input type="number" name="price_per_night" step="0.01" min="0"
                 value="<%= room ? room.price_per_night : '' %>" required>
        </div>
        <div class="form-group">
          <label>Capacity (guests)</label>
          <input type="number" name="capacity" min="1" value="<%= room ? room.capacity : 2 %>">
        </div>
        <div class="form-group">
          <label>Total Units</label>
          <input type="number" name="total_units" min="1" value="<%= room ? room.total_units : 1 %>">
        </div>
      </div>

      <h3>Descriptions by Language</h3>

      <div class="form-group">
        <label>🇪🇸 Description (Español)</label>
        <textarea name="description_es" rows="3"><%= room ? room.description_es : '' %></textarea>
      </div>
      <div class="form-group">
        <label>🇬🇧 Description (English)</label>
        <textarea name="description_en" rows="3"><%= room ? room.description_en : '' %></textarea>
      </div>
      <div class="form-group">
        <label>🇧🇷 Descrição (Português)</label>
        <textarea name="description_pt" rows="3"><%= room ? room.description_pt : '' %></textarea>
      </div>

      <div class="form-group">
        <label>Amenities (JSON array, e.g.: ["WiFi", "TV", "Minibar"])</label>
        <input type="text" name="amenities" value='<%= room ? room.amenities : "[]" %>'>
      </div>

      <div class="form-group">
        <label>Image URL</label>
        <input type="text" name="image_url" value="<%= room ? room.image_url : '' %>">
      </div>

      <div class="form-group checkbox-group">
        <label>
          <input type="checkbox" name="is_active" value="1"
                 <%= (!room || room.is_active) ? 'checked' : '' %>>
          Room Active
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/admin/rooms" class="btn">Cancel</a>
      </div>
    </form>
  </main>
  <script src="/js/admin.js"></script>
</body>
</html>
